<UserControl
    x:Class="ThunderEagle.FilterForge.App.Views.AiAssistantView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:ThunderEagle.FilterForge.App.ViewModels"
    mc:Ignorable="d"
    d:DataContext="{d:DesignInstance Type=vm:AiAssistantViewModel, IsDesignTimeCreatable=False}">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>

    <Border BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}"
            BorderThickness="0,1,0,0"
            Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}">
        <DockPanel Margin="8,6,8,6">

            <!-- ── Settings expander (docked top) ─────────────────────── -->
            <Expander DockPanel.Dock="Top" Header="Provider Settings" IsExpanded="False" Margin="0,0,0,6">
                <Grid Margin="4,4,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="90" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="90" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Row 0: Base URL -->
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Base URL" VerticalAlignment="Center" />
                    <TextBox Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="3"
                             Text="{Binding BaseUrl, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,2,0,2" />

                    <!-- Row 1: Model -->
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Model" VerticalAlignment="Center" />
                    <DockPanel Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="3" Margin="0,2,0,2">
                        <Button DockPanel.Dock="Right"
                                Command="{Binding RefreshModelsCommand}"
                                Content="⟳" FontSize="14"
                                ToolTip="Fetch available models from Ollama"
                                Padding="6,1" Margin="4,0,0,0" />
                        <ComboBox IsEditable="True"
                                  Text="{Binding ModelName, UpdateSourceTrigger=PropertyChanged}"
                                  ItemsSource="{Binding AvailableModels}" />
                    </DockPanel>
                </Grid>
            </Expander>

            <!-- Buttons outside expander content but inside DockPanel, docked top after expander -->
            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal"
                        HorizontalAlignment="Right" Margin="0,0,0,6">
                <Button Command="{Binding TestConnectionCommand}"
                        Content="Test Connection" Padding="8,2" Margin="0,0,6,0" />
                <Button Command="{Binding SaveSettingsCommand}"
                        Content="Save Settings" Padding="8,2" />
            </StackPanel>

            <!-- ── Prompt + generate (docked top) ────────────────────── -->
            <Grid DockPanel.Dock="Top" Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBox Grid.Column="0"
                         x:Name="PromptBox"
                         Text="{Binding UserPrompt, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="False"
                         TextWrapping="Wrap"
                         MinLines="2"
                         MaxLines="5"
                         VerticalScrollBarVisibility="Auto"
                         ToolTip="Describe the rule — Enter to generate, Ctrl+Enter for a new line"
                         KeyDown="PromptBox_KeyDown"
                         Margin="0,0,6,0" />

                <StackPanel Grid.Column="1" VerticalAlignment="Top">
                    <Button Command="{Binding GenerateRuleCommand}"
                            Content="Generate Rule"
                            Padding="10,4"
                            MinWidth="110" />
                    <ProgressBar IsIndeterminate="True" Height="4" Margin="0,4,0,0"
                                 Visibility="{Binding IsGenerating, Converter={StaticResource BoolToVis}}" />
                </StackPanel>
            </Grid>

            <!-- ── Result area ────────────────────────────────────────── -->
            <StackPanel DockPanel.Dock="Top">

                <TextBlock Text="{Binding StatusText}" TextWrapping="Wrap" Margin="0,0,0,4">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasError}" Value="True">
                                    <Setter Property="Foreground" Value="Red" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <Border Visibility="{Binding HasPendingRule, Converter={StaticResource BoolToVis}}"
                        BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}"
                        BorderThickness="1" CornerRadius="3" Padding="6,4" Margin="0,0,0,2">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                            <Button Command="{Binding AddRuleCommand}"
                                    Content="Add to Filter" Padding="8,2" Margin="0,0,6,0" />
                            <Button Command="{Binding DiscardRuleCommand}"
                                    Content="Discard" Padding="8,2" />
                        </StackPanel>
                        <TextBlock Text="{Binding PendingRuleSummary}" VerticalAlignment="Center"
                                   FontWeight="SemiBold" />
                    </DockPanel>
                </Border>

            </StackPanel>

        </DockPanel>
    </Border>
</UserControl>
