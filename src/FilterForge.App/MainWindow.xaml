<Window
    x:Class="ThunderEagle.FilterForge.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:views="clr-namespace:ThunderEagle.FilterForge.App.Views"
    xmlns:vm="clr-namespace:ThunderEagle.FilterForge.App.ViewModels"
    mc:Ignorable="d"
    d:DataContext="{d:DesignInstance Type=vm:MainWindowViewModel, IsDesignTimeCreatable=False}"
    Title="FilterForge — Filter Editor"
    Icon="Assets/filterforge.ico"
    Height="700" Width="1100"
    MinHeight="450" MinWidth="700">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </Window.Resources>

    <DockPanel>

        <!-- ── Toolbar ──────────────────────────────────────────────── -->
        <ToolBarTray DockPanel.Dock="Top" IsLocked="True">
            <ToolBar>
                <Button Command="{Binding NewFilterCommand}"
                        ToolTip="Create an empty filter"
                        Padding="8,2">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE8A5;" FontFamily="Segoe MDL2 Assets" FontSize="14" VerticalAlignment="Center" Margin="0,0,5,0" />
                        <TextBlock Text="New" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>

                <Separator />

                <Button Command="{Binding PasteCodeCommand}"
                        ToolTip="Import a D4 filter share code from the clipboard"
                        Padding="8,2">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE77F;" FontFamily="Segoe MDL2 Assets" FontSize="14" VerticalAlignment="Center" Margin="0,0,5,0" />
                        <TextBlock Text="Paste Code" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
                <Button Command="{Binding OpenJsonCommand}"
                        ToolTip="Open a previously saved filter JSON file"
                        Padding="8,2">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets" FontSize="14" VerticalAlignment="Center" Margin="0,0,5,0" />
                        <TextBlock Text="Open JSON…" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>

                <Separator />

                <Button Command="{Binding CopyCodeCommand}"
                        ToolTip="Export the filter as a D4 share code to the clipboard (max 25 rules; disabled when validation errors exist)"
                        Padding="8,2">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE8C8;" FontFamily="Segoe MDL2 Assets" FontSize="14" VerticalAlignment="Center" Margin="0,0,5,0" />
                        <TextBlock Text="Copy Code" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
                <Button Command="{Binding SaveJsonCommand}"
                        ToolTip="Save the filter as a local JSON file"
                        Padding="8,2">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE74E;" FontFamily="Segoe MDL2 Assets" FontSize="14" VerticalAlignment="Center" Margin="0,0,5,0" />
                        <TextBlock Text="Save JSON…" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>

                <Separator />

                <Button Command="{Binding OpenRawEditorCommand}"
                        ToolTip="Open the JSON raw editor in a separate window"
                        Padding="8,2">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE8D4;" FontFamily="Segoe MDL2 Assets" FontSize="14" VerticalAlignment="Center" Margin="0,0,5,0" />
                        <TextBlock Text="Raw Editor" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>

                <Separator />

                <Button Command="{Binding ValidateCommand}"
                        ToolTip="Check the filter against game-enforced rules"
                        Padding="8,2">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Foreground" Value="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasBlockingErrors}" Value="True">
                                    <Setter Property="Foreground" Value="Red" />
                                    <Setter Property="FontWeight" Value="SemiBold" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" FontSize="14" VerticalAlignment="Center" Margin="0,0,5,0" />
                        <TextBlock Text="{Binding IssuesBadge}" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>

                <Separator />

                <ToggleButton IsChecked="{Binding IsAiPanelVisible}"
                              ToolTip="Toggle AI rule assistant panel"
                              Padding="8,2">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE70B;" FontFamily="Segoe MDL2 Assets" FontSize="14" VerticalAlignment="Center" Margin="0,0,5,0" />
                        <TextBlock Text="AI Assistant" VerticalAlignment="Center" />
                    </StackPanel>
                </ToggleButton>

            </ToolBar>
        </ToolBarTray>

        <!-- ── Issues panel (collapsed when empty) ─────────────────── -->
        <views:IssuesPanel DockPanel.Dock="Top" Issues="{Binding Issues}">
            <views:IssuesPanel.Style>
                <Style TargetType="views:IssuesPanel">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding HasIssues}" Value="True">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </views:IssuesPanel.Style>
        </views:IssuesPanel>

        <!-- ── Status bar ───────────────────────────────────────────── -->
        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusMessage}">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasError}" Value="True">
                                    <Setter Property="Foreground" Value="Red" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </StatusBarItem>
        </StatusBar>

        <!-- ── Main content area + AI panel ────────────────────────── -->
        <!--
            Row heights are driven from code-behind when IsAiPanelVisible changes
            so the splitter can genuinely resize between rows 0 and 2.
        -->
        <Grid x:Name="ContentGrid">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="0" />
                <RowDefinition Height="0" />
            </Grid.RowDefinitions>

            <ContentControl Grid.Row="0" Content="{Binding Editor}">

                <!-- Placeholder when no filter is loaded -->
                <ContentControl.Style>
                    <Style TargetType="ContentControl">
                        <Style.Triggers>
                            <Trigger Property="Content" Value="{x:Null}">
                                <Setter Property="ContentTemplate">
                                    <Setter.Value>
                                        <DataTemplate>
                                            <StackPanel HorizontalAlignment="Center"
                                                        VerticalAlignment="Center">
                                                <TextBlock Text="FilterForge — Filter Editor"
                                                           FontSize="22" FontWeight="Light"
                                                           HorizontalAlignment="Center"
                                                           Margin="0,0,0,12" />
                                                <TextBlock Text="Paste a D4 filter share code, open a JSON file, or create a new filter."
                                                           Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                                                           HorizontalAlignment="Center" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </ContentControl.Style>

                <!-- Visual editor fills the content area when a filter is loaded -->
                <ContentControl.Resources>
                    <DataTemplate DataType="{x:Type vm:VisualEditorViewModel}">
                        <views:VisualEditorView />
                    </DataTemplate>
                </ContentControl.Resources>

            </ContentControl>

            <GridSplitter x:Name="AiSplitter" Grid.Row="1"
                          HorizontalAlignment="Stretch" ResizeBehavior="PreviousAndNext" />

            <views:AiAssistantView x:Name="AiPanel" Grid.Row="2"
                                   DataContext="{Binding AiAssistant}" />

        </Grid>
    </DockPanel>
</Window>
