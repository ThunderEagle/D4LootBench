<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        Light theme — maps semantic App.* keys to Windows system defaults.
        No SystemColors overrides; the native Aero appearance is preserved.
    -->

    <!-- Semantic aliases used by any view that wants explicit theme-awareness -->
    <SolidColorBrush x:Key="App.WindowBackground"  Color="{x:Static SystemColors.WindowColor}" />
    <SolidColorBrush x:Key="App.PrimaryText"       Color="{x:Static SystemColors.ControlTextColor}" />
    <SolidColorBrush x:Key="App.SecondaryText"     Color="{x:Static SystemColors.GrayTextColor}" />
    <SolidColorBrush x:Key="App.CardBorder"        Color="{x:Static SystemColors.ControlLightColor}" />
    <SolidColorBrush x:Key="App.Divider"           Color="{x:Static SystemColors.ControlDarkColor}" />
    <SolidColorBrush x:Key="App.AccentBrush"       Color="{x:Static SystemColors.HighlightColor}" />
    <SolidColorBrush x:Key="App.AccentForeground"  Color="{x:Static SystemColors.HighlightTextColor}" />

</ResourceDictionary>
