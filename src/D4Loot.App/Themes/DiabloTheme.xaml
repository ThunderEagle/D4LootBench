<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        Diablo theme — near-black backgrounds, deep crimson accents, warm parchment text.
        Inspired by the D4 in-game loot filter UI.
    -->

    <!-- ── SystemColors overrides ──────────────────────────────────────── -->
    <Color x:Key="{x:Static SystemColors.WindowColorKey}">#0A0808</Color>
    <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#0A0808" />

    <Color x:Key="{x:Static SystemColors.WindowTextColorKey}">#E8DDD5</Color>
    <SolidColorBrush x:Key="{x:Static SystemColors.WindowTextBrushKey}" Color="#E8DDD5" />

    <Color x:Key="{x:Static SystemColors.ControlColorKey}">#141010</Color>
    <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}" Color="#141010" />

    <Color x:Key="{x:Static SystemColors.ControlTextColorKey}">#E8DDD5</Color>
    <SolidColorBrush x:Key="{x:Static SystemColors.ControlTextBrushKey}" Color="#E8DDD5" />

    <!-- ControlLight = condition card border / subtle dividers -->
    <Color x:Key="{x:Static SystemColors.ControlLightColorKey}">#3A1C1C</Color>
    <SolidColorBrush x:Key="{x:Static SystemColors.ControlLightBrushKey}" Color="#3A1C1C" />

    <!-- ControlDark = splitter, color swatch stroke, hue cursor stroke -->
    <Color x:Key="{x:Static SystemColors.ControlDarkColorKey}">#6A2828</Color>
    <SolidColorBrush x:Key="{x:Static SystemColors.ControlDarkBrushKey}" Color="#6A2828" />

    <Color x:Key="{x:Static SystemColors.ControlDarkDarkColorKey}">#200E0E</Color>
    <SolidColorBrush x:Key="{x:Static SystemColors.ControlDarkDarkBrushKey}" Color="#200E0E" />

    <!-- GrayText = secondary / caption / summary text -->
    <Color x:Key="{x:Static SystemColors.GrayTextColorKey}">#7A6E65</Color>
    <SolidColorBrush x:Key="{x:Static SystemColors.GrayTextBrushKey}" Color="#7A6E65" />

    <!-- ListBox item selection -->
    <Color x:Key="{x:Static SystemColors.HighlightColorKey}">#7A1515</Color>
    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#7A1515" />

    <Color x:Key="{x:Static SystemColors.HighlightTextColorKey}">#F0E0D0</Color>
    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#F0E0D0" />

    <Color x:Key="{x:Static SystemColors.InactiveSelectionHighlightColorKey}">#4A1010</Color>
    <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#4A1010" />

    <Color x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextColorKey}">#C8BCB0</Color>
    <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="#C8BCB0" />

    <!-- Menu / toolbar band -->
    <Color x:Key="{x:Static SystemColors.MenuColorKey}">#0F0B0B</Color>
    <SolidColorBrush x:Key="{x:Static SystemColors.MenuBrushKey}" Color="#0F0B0B" />

    <Color x:Key="{x:Static SystemColors.MenuTextColorKey}">#E8DDD5</Color>
    <SolidColorBrush x:Key="{x:Static SystemColors.MenuTextBrushKey}" Color="#E8DDD5" />

    <!-- ── Semantic App.* keys ──────────────────────────────────────────── -->
    <SolidColorBrush x:Key="App.WindowBackground"  Color="#0A0808" />
    <SolidColorBrush x:Key="App.PrimaryText"       Color="#E8DDD5" />
    <SolidColorBrush x:Key="App.SecondaryText"     Color="#7A6E65" />
    <SolidColorBrush x:Key="App.CardBorder"        Color="#3A1C1C" />
    <SolidColorBrush x:Key="App.Divider"           Color="#6A2828" />
    <SolidColorBrush x:Key="App.AccentBrush"       Color="#7A1515" />
    <SolidColorBrush x:Key="App.AccentForeground"  Color="#F0E0D0" />

    <!-- ── Implicit control styles ──────────────────────────────────────── -->

    <Style TargetType="Window">
        <Setter Property="Background" Value="#0A0808" />
    </Style>

    <Style TargetType="ToolBarTray">
        <Setter Property="Background" Value="#0F0B0B" />
    </Style>

    <Style TargetType="ToolBar">
        <Setter Property="Background" Value="#0F0B0B" />
    </Style>

    <Style TargetType="StatusBar">
        <Setter Property="Background" Value="#0F0B0B" />
        <Setter Property="Foreground" Value="#7A6E65" />
    </Style>

    <Style TargetType="Separator">
        <Setter Property="Background" Value="#3A1C1C" />
    </Style>

    <Style TargetType="TextBox">
        <Setter Property="Background"     Value="#100C0C" />
        <Setter Property="Foreground"     Value="#E8DDD5" />
        <Setter Property="BorderBrush"    Value="#5A2828" />
        <Setter Property="CaretBrush"     Value="#E8DDD5" />
        <Setter Property="SelectionBrush" Value="#7A1515" />
    </Style>

    <Style TargetType="ComboBox">
        <Setter Property="Background"  Value="#1A0E0E" />
        <Setter Property="Foreground"  Value="#E8DDD5" />
        <Setter Property="BorderBrush" Value="#5A2828" />
    </Style>

    <Style TargetType="ListBox">
        <Setter Property="Background"  Value="#0F0B0B" />
        <Setter Property="Foreground"  Value="#E8DDD5" />
        <Setter Property="BorderBrush" Value="#3A1C1C" />
    </Style>

    <Style TargetType="CheckBox">
        <Setter Property="Foreground" Value="#E8DDD5" />
    </Style>

    <Style TargetType="Label">
        <Setter Property="Foreground" Value="#E8DDD5" />
    </Style>

    <Style TargetType="Button">
        <Setter Property="Background"                 Value="#1A0E0E" />
        <Setter Property="Foreground"                 Value="#C8BCB0" />
        <Setter Property="BorderBrush"                Value="#7A2020" />
        <Setter Property="BorderThickness"            Value="1" />
        <Setter Property="Padding"                    Value="4,2" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment"   Value="Center" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background"  Value="#2E1515" />
                            <Setter TargetName="bd" Property="BorderBrush" Value="#9B2020" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="bd" Property="Background"  Value="#4A1515" />
                            <Setter TargetName="bd" Property="BorderBrush" Value="#C02020" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="bd" Property="Opacity" Value="0.4" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
