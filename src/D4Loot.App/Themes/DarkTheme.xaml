<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        Dark theme — VS Code / Windows dark palette.
        Overrides SystemColors keys so all existing DynamicResource bindings update automatically.
    -->

    <!-- ── SystemColors overrides ──────────────────────────────────────── -->
    <Color x:Key="{x:Static SystemColors.WindowColorKey}">#1E1E1E</Color>
    <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#1E1E1E" />

    <Color x:Key="{x:Static SystemColors.WindowTextColorKey}">#D4D4D4</Color>
    <SolidColorBrush x:Key="{x:Static SystemColors.WindowTextBrushKey}" Color="#D4D4D4" />

    <Color x:Key="{x:Static SystemColors.ControlColorKey}">#252526</Color>
    <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}" Color="#252526" />

    <Color x:Key="{x:Static SystemColors.ControlTextColorKey}">#D4D4D4</Color>
    <SolidColorBrush x:Key="{x:Static SystemColors.ControlTextBrushKey}" Color="#D4D4D4" />

    <Color x:Key="{x:Static SystemColors.ControlLightColorKey}">#3F3F46</Color>
    <SolidColorBrush x:Key="{x:Static SystemColors.ControlLightBrushKey}" Color="#3F3F46" />

    <Color x:Key="{x:Static SystemColors.ControlDarkColorKey}">#3F3F46</Color>
    <SolidColorBrush x:Key="{x:Static SystemColors.ControlDarkBrushKey}" Color="#3F3F46" />

    <Color x:Key="{x:Static SystemColors.ControlDarkDarkColorKey}">#2D2D30</Color>
    <SolidColorBrush x:Key="{x:Static SystemColors.ControlDarkDarkBrushKey}" Color="#2D2D30" />

    <Color x:Key="{x:Static SystemColors.GrayTextColorKey}">#858585</Color>
    <SolidColorBrush x:Key="{x:Static SystemColors.GrayTextBrushKey}" Color="#858585" />

    <Color x:Key="{x:Static SystemColors.HighlightColorKey}">#094771</Color>
    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#094771" />

    <Color x:Key="{x:Static SystemColors.HighlightTextColorKey}">#FFFFFF</Color>
    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#FFFFFF" />

    <Color x:Key="{x:Static SystemColors.InactiveSelectionHighlightColorKey}">#37373D</Color>
    <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#37373D" />

    <Color x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextColorKey}">#D4D4D4</Color>
    <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="#D4D4D4" />

    <Color x:Key="{x:Static SystemColors.MenuColorKey}">#2D2D30</Color>
    <SolidColorBrush x:Key="{x:Static SystemColors.MenuBrushKey}" Color="#2D2D30" />

    <Color x:Key="{x:Static SystemColors.MenuTextColorKey}">#D4D4D4</Color>
    <SolidColorBrush x:Key="{x:Static SystemColors.MenuTextBrushKey}" Color="#D4D4D4" />

    <!-- ── Semantic App.* keys ──────────────────────────────────────────── -->
    <SolidColorBrush x:Key="App.WindowBackground"  Color="#1E1E1E" />
    <SolidColorBrush x:Key="App.PrimaryText"       Color="#D4D4D4" />
    <SolidColorBrush x:Key="App.SecondaryText"     Color="#858585" />
    <SolidColorBrush x:Key="App.CardBorder"        Color="#3F3F46" />
    <SolidColorBrush x:Key="App.Divider"           Color="#3F3F46" />
    <SolidColorBrush x:Key="App.AccentBrush"       Color="#094771" />
    <SolidColorBrush x:Key="App.AccentForeground"  Color="#FFFFFF" />

    <!-- ── Implicit control styles ──────────────────────────────────────── -->

    <Style TargetType="Window">
        <Setter Property="Background" Value="#1E1E1E" />
    </Style>

    <Style TargetType="ToolBarTray">
        <Setter Property="Background" Value="#2D2D30" />
    </Style>

    <Style TargetType="ToolBar">
        <Setter Property="Background" Value="#2D2D30" />
    </Style>

    <Style TargetType="StatusBar">
        <Setter Property="Background" Value="#007ACC" />
        <Setter Property="Foreground" Value="#FFFFFF" />
    </Style>

    <Style TargetType="TextBox">
        <Setter Property="Background"   Value="#3C3C3C" />
        <Setter Property="Foreground"   Value="#D4D4D4" />
        <Setter Property="BorderBrush"  Value="#3F3F46" />
        <Setter Property="CaretBrush"   Value="#D4D4D4" />
        <Setter Property="SelectionBrush" Value="#264F78" />
    </Style>

    <Style TargetType="ComboBox">
        <Setter Property="Background"  Value="#3C3C3C" />
        <Setter Property="Foreground"  Value="#D4D4D4" />
        <Setter Property="BorderBrush" Value="#3F3F46" />
    </Style>

    <Style TargetType="ListBox">
        <Setter Property="Background"  Value="#252526" />
        <Setter Property="Foreground"  Value="#D4D4D4" />
        <Setter Property="BorderBrush" Value="#3F3F46" />
    </Style>

    <Style TargetType="CheckBox">
        <Setter Property="Foreground" Value="#D4D4D4" />
    </Style>

    <Style TargetType="Label">
        <Setter Property="Foreground" Value="#D4D4D4" />
    </Style>

    <Style TargetType="Button">
        <Setter Property="Background"              Value="#3C3C3C" />
        <Setter Property="Foreground"              Value="#D4D4D4" />
        <Setter Property="BorderBrush"             Value="#5A5A5A" />
        <Setter Property="BorderThickness"         Value="1" />
        <Setter Property="Padding"                 Value="4,2" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment"   Value="Center" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background"   Value="#4A4A4A" />
                            <Setter TargetName="bd" Property="BorderBrush"  Value="#808080" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="bd" Property="Background"   Value="#0E639C" />
                            <Setter TargetName="bd" Property="BorderBrush"  Value="#0E639C" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="bd" Property="Opacity" Value="0.4" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
