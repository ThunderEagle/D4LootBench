<Window
    x:Class="D4Loot.App.Views.RawEditorWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:avalonEdit="http://icsharpcode.net/sharpdevelop/avalonedit"
    xmlns:conv="clr-namespace:D4Loot.App.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:D4Loot.App.ViewModels"
    mc:Ignorable="d"
    d:DataContext="{d:DesignInstance Type=vm:RawEditorViewModel, IsDesignTimeCreatable=False}"
    Title="Raw Editor"
    Width="900" Height="650"
    MinWidth="600" MinHeight="400"
    WindowStartupLocation="CenterOwner">

    <Window.Resources>
        <conv:BoolToBrushConverter x:Key="ErrorBrushConverter" />
    </Window.Resources>

    <DockPanel>
        <!-- Toolbar -->
        <ToolBar DockPanel.Dock="Top" ToolBarTray.IsLocked="True">
            <Button Content="Apply"
                    Command="{Binding ApplyCommand}"
                    ToolTip="Parse JSON and apply changes to the visual editor"
                    Padding="10,2" FontWeight="SemiBold" />
            <Separator />
            <Button Content="Close"
                    Click="OnCloseClick"
                    Padding="8,2" />
        </ToolBar>

        <!-- Status bar -->
        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusMessage}"
                           Foreground="{Binding HasError, Converter={StaticResource ErrorBrushConverter}}" />
            </StatusBarItem>
        </StatusBar>

        <!-- Editor -->
        <avalonEdit:TextEditor
            x:Name="Editor"
            SyntaxHighlighting="JavaScript"
            FontFamily="Cascadia Code, Consolas, Courier New"
            FontSize="13"
            ShowLineNumbers="True"
            WordWrap="False"
            HorizontalScrollBarVisibility="Auto"
            VerticalScrollBarVisibility="Auto" />
    </DockPanel>
</Window>
