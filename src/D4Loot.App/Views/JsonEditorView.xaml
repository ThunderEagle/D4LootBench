<UserControl x:Class="D4Loot.App.Views.JsonEditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:D4Loot.App.Views"
             xmlns:vm="clr-namespace:D4Loot.App.ViewModels"
             xmlns:avalonEdit="http://icsharpcode.net/sharpdevelop/avalonedit"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:JsonEditorViewModel, IsDesignTimeCreatable=False}">

    <UserControl.Resources>
        <local:BoolToBrushConverter x:Key="ErrorBrushConverter"/>
    </UserControl.Resources>

    <DockPanel>

        <ToolBar DockPanel.Dock="Top" ToolBarTray.IsLocked="True">
            <Button Command="{Binding PasteCodeCommand}"
                    Content="Paste Code"
                    ToolTip="Decode a filter share code from the clipboard and display as JSON"/>
            <Separator/>
            <Button Command="{Binding CopyCodeCommand}"
                    Content="Copy Code"
                    ToolTip="Encode the current JSON and copy the share code to the clipboard"/>
        </ToolBar>

        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusMessage}"
                           Foreground="{Binding HasError, Converter={StaticResource ErrorBrushConverter}}"/>
            </StatusBarItem>
        </StatusBar>

        <avalonEdit:TextEditor x:Name="Editor"
                               SyntaxHighlighting="JavaScript"
                               FontFamily="Cascadia Code, Consolas, Courier New"
                               FontSize="13"
                               ShowLineNumbers="True"
                               WordWrap="False"
                               HorizontalScrollBarVisibility="Auto"
                               VerticalScrollBarVisibility="Auto"/>
    </DockPanel>

</UserControl>
