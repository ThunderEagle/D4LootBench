<Window
    x:Class="D4Loot.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:views="clr-namespace:D4Loot.App.Views"
    xmlns:vm="clr-namespace:D4Loot.App.ViewModels"
    mc:Ignorable="d"
    d:DataContext="{d:DesignInstance Type=vm:MainWindowViewModel, IsDesignTimeCreatable=False}"
    Title="D4Loot — Filter Editor"
    Height="700" Width="1100"
    MinHeight="450" MinWidth="700">

    <DockPanel>

        <!-- ── Toolbar ──────────────────────────────────────────────── -->
        <ToolBarTray DockPanel.Dock="Top" IsLocked="True">
            <ToolBar>
                <Button Content="New"
                        Command="{Binding NewFilterCommand}"
                        ToolTip="Create an empty filter"
                        Padding="8,2" />

                <Separator />

                <Button Content="Paste Code"
                        Command="{Binding PasteCodeCommand}"
                        ToolTip="Import a D4 filter share code from the clipboard"
                        Padding="8,2" />
                <Button Content="Open JSON…"
                        Command="{Binding OpenJsonCommand}"
                        ToolTip="Open a previously saved filter JSON file"
                        Padding="8,2" />

                <Separator />

                <Button Content="Copy Code"
                        Command="{Binding CopyCodeCommand}"
                        ToolTip="Export the filter as a D4 share code to the clipboard (max 25 rules; disabled when validation errors exist)"
                        Padding="8,2" />
                <Button Content="Save JSON…"
                        Command="{Binding SaveJsonCommand}"
                        ToolTip="Save the filter as a local JSON file"
                        Padding="8,2" />

                <Separator />

                <Button Content="Raw Editor"
                        Command="{Binding OpenRawEditorCommand}"
                        ToolTip="Open the JSON raw editor in a separate window"
                        Padding="8,2" />

                <Separator />

                <Button Content="{Binding IssuesBadge}"
                        Command="{Binding ValidateCommand}"
                        ToolTip="Check the filter against game-enforced rules"
                        Padding="8,2">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Foreground" Value="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasBlockingErrors}" Value="True">
                                    <Setter Property="Foreground" Value="Red" />
                                    <Setter Property="FontWeight" Value="SemiBold" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

            </ToolBar>
        </ToolBarTray>

        <!-- ── Issues panel (collapsed when empty) ─────────────────── -->
        <views:IssuesPanel DockPanel.Dock="Top" Issues="{Binding Issues}">
            <views:IssuesPanel.Style>
                <Style TargetType="views:IssuesPanel">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding HasIssues}" Value="True">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </views:IssuesPanel.Style>
        </views:IssuesPanel>

        <!-- ── Status bar ───────────────────────────────────────────── -->
        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusMessage}">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasError}" Value="True">
                                    <Setter Property="Foreground" Value="Red" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </StatusBarItem>
        </StatusBar>

        <!-- ── Main content area ────────────────────────────────────── -->
        <ContentControl Content="{Binding Editor}">

            <!-- Placeholder when no filter is loaded -->
            <ContentControl.Style>
                <Style TargetType="ContentControl">
                    <Style.Triggers>
                        <Trigger Property="Content" Value="{x:Null}">
                            <Setter Property="ContentTemplate">
                                <Setter.Value>
                                    <DataTemplate>
                                        <StackPanel HorizontalAlignment="Center"
                                                    VerticalAlignment="Center">
                                            <TextBlock Text="D4Loot — Filter Editor"
                                                       FontSize="22" FontWeight="Light"
                                                       HorizontalAlignment="Center"
                                                       Margin="0,0,0,12" />
                                            <TextBlock Text="Paste a D4 filter share code, open a JSON file, or create a new filter."
                                                       Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                                                       HorizontalAlignment="Center" />
                                        </StackPanel>
                                    </DataTemplate>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </ContentControl.Style>

            <!-- Visual editor fills the content area when a filter is loaded -->
            <ContentControl.Resources>
                <DataTemplate DataType="{x:Type vm:VisualEditorViewModel}">
                    <views:VisualEditorView />
                </DataTemplate>
            </ContentControl.Resources>

        </ContentControl>
    </DockPanel>
</Window>
